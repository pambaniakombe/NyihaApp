# Copy to .env.railway (gitignored) for running Prisma from your laptop against Railway Postgres.
#
# Use the PUBLIC / external connection string only — host must NOT be postgres.railway.internal
# (that hostname only works inside Railway's network).
#
# Railway Dashboard → Postgres → Connect → use the URL for public / TCP proxy access.

DATABASE_URL="postgresql://USER:PASSWORD@SHORTNAME.proxy.rlwy.net:PORT/railway"
