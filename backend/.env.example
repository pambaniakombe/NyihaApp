# Railway injects DATABASE_URL when you add a PostgreSQL plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Generate a long random string for production
JWT_SECRET="change-me-to-a-long-random-string"

# Server (Railway sets PORT in production, e.g. 8080 — do not rely on a fixed port locally)
PORT=3000
NODE_ENV=development

# Production API hostname (for docs only; clients use https://nyihaapp-production-4ca7.up.railway.app)
# Optional: comma-separated *browser* origins allowed by CORS (Flutter web / admin sites), not the API URL itself
CORS_ORIGINS="http://localhost:8080,http://localhost:3000,http://localhost:52734"
